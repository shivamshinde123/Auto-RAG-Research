# =============================================================================
# AutoRAGResearch — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your enabled data sources.
# Only the variables for your enabled sources are required.
# =============================================================================

# --- OpenAI (Required for RAG pipeline and agent) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- AWS S3 (Required only if s3 data source is enabled) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# --- Notion (Required only if notion data source is enabled) ---
NOTION_API_KEY=your-notion-api-key-here

# --- HuggingFace (Optional — needed for private datasets or higher rate limits) ---
HUGGINGFACE_TOKEN=your-huggingface-token-here
